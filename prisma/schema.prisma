// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workshop {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  createdAt DateTime @default(now())

  drones Drone[]
}

model Drone {
  id          String        @id @default(cuid())
  qrCode      String        @unique

  status      DroneStatus   @default(GENERATED)

  workshopId  String?
  workshop    Workshop?     @relation(fields: [workshopId], references: [id])

  batchId     String?
  batch       Batch?        @relation(fields: [batchId], references: [id])

  typeId      String?
  type        DroneType?    @relation(fields: [typeId], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Batch {
  id        String        @id @default(cuid())
  name      String?

  status    BatchStatus   @default(CREATED)

  drones    Drone[]

  reports   Report[]

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  destination String?
  attachments BatchAttachment[]
}

model BatchAttachment {
  id        String   @id @default(cuid())
  url       String
  fileName  String?
  mimeType  String?

  batchId   String
  batch     Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model DroneType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  drones      Drone[]
}

model Report {
  id        String   @id @default(cuid())

  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id])

  content   String?   // text report
  mediaUrl  String?   // video/photo link

  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  role      Role     @default(USER)

  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

enum DroneStatus {
  GENERATED     // QR created
  ASSEMBLED     // built
  TESTED        // after flight test
  PACKED        // assigned to batch
  SHIPPED       // sent
  DELIVERED     // received
  REPORTED      // confirmed by report
}

enum BatchStatus {
  CREATED
  PACKED
  SHIPPED
  DELIVERED
  REPORTED
}